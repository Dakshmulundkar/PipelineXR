# ----------------------------------------------------------------------
# 1. GitHub Configuration
# ----------------------------------------------------------------------
# Get these from GitHub Settings -> Developer Settings -> OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# (Essential) Personal Access Token (PAT) for API triggers and stats
# Source: GitHub Settings -> Developer Settings -> Personal Access Tokens (Classic)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ----------------------------------------------------------------------
# 2. Application Configuration
# ----------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:5174
SESSION_SECRET=a_secure_random_string_123!

# ----------------------------------------------------------------------
# 2a. Database — Neon PostgreSQL
# ----------------------------------------------------------------------
# Create a free project at neon.tech, then copy the connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------------------
# 3. AI & Security Integrations
# ----------------------------------------------------------------------
# Google Gemini for AI Remediation steps (Free at aistudio.google.com)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Snyk API Configuration
# Get your Personal API Token from Snyk -> Account Settings
SNYK_TOKEN=your_snyk_api_token_here
# Get your Organization ID from Snyk -> Settings (found on the page you are currently viewing)
SNYK_ORG_ID=your_snyk_org_id_here


# (Optional) GitHub Webhook Secret for signature validation
GITHUB_WEBHOOK_SECRET=your_webhook_validation_secret_here

# ----------------------------------------------------------------------
# 4. Datadog Observability (optional)
# ----------------------------------------------------------------------
# Create account at datadoghq.com — select AP1 (Tokyo) region for India
# Get keys from: Organization Settings -> API Keys / Application Keys
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_APP_KEY=your_datadog_app_key_here
DATADOG_SITE=ap1.datadoghq.com

# ----------------------------------------------------------------------
# 5. Email (Resend — free tier: 3,000 emails/month, no credit card)
# ----------------------------------------------------------------------
# Sign up at resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key_here

# Optional: custom from address (requires a verified domain in Resend)
# Leave blank to use Resend's shared domain (onboarding@resend.dev)
RESEND_FROM=PipelineXR <you@yourdomain.com>

# Your GitHub login is resolved automatically from GITHUB_TOKEN above.
# Whoever owns that token gets admin access — no separate env var needed.
