{
  "name": "devops-hakathon",
  "version": "1.0.0",
  "description": "PipelineXR - Comprehensive DevOps Analytics Dashboard",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node start-both.js",
    "test:oauth": "node test-oauth-setup.js",
    "deploy": "node deploy.js deploy",
    "stop": "node deploy.js stop",
    "status": "node deploy.js status",
    "test": "node test-integration.js",
    "test:health": "node deploy.js && echo 'Health checks passed'",
    "build": "echo 'No build step required for this project'",
    "logs": "tail -f deployment.log",
    "full-deploy": "npm run deploy && npm run test",
    "webhook:setup": "node setup-github-webhook.js",
    "webhook:test": "node test-github-webhook.js",
    "install:trivy": "curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b ./"
  },
  "keywords": [
    "devops",
    "analytics",
    "dashboard",
    "ci-cd",
    "monitoring"
  ],
  "author": "PipelineXR Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@datadog/datadog-api-client": "^1.53.0",
    "@google/generative-ai": "^0.24.1",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "octokit": "^5.0.5",
    "puppeteer": "^24.38.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.0.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/pipelinexr"
  },
  "bugs": {
    "url": "https://github.com/your-org/pipelinexr/issues"
  },
  "homepage": "https://github.com/your-org/pipelinexr#readme"
}
